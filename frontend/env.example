# Frontend env vars (Vite — MUST be prefixed with VITE_ to reach the bundle).
# In production these are managed by Doppler and synced to Vercel via the
# Doppler-Vercel integration; locally copy this file to `.env` or run
# `doppler run -- npm run dev`.

# Backend HTTPS origin — empty string in dev (Vite proxy handles /api).
VITE_API_URL=https://api.yourdomain.com

# Backend Socket.IO origin — same host as VITE_API_URL in single-domain setups.
VITE_SOCKET_URL=https://api.yourdomain.com

# Agora App ID. The backend's /api/agora/token response always wins in prod,
# so this is mostly a safety fallback for testing.
VITE_AGORA_APP_ID=

# Optional: Giphy public API key for the GIF picker
VITE_GIPHY_API_KEY=
